# Household AI Assistant System - Environment Variables Template
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# ===== API Gateway =====
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ===== OpenClaw Integration =====
# Point to your OpenClaw instance
OPENCLAW_BASE_URL=http://localhost:8001
OPENCLAW_API_KEY=your_openclaw_api_key_here

# ===== OpenClaw Containerized Service =====
# Docker image for OpenClaw (leave default or specify custom image)
# Default: lantern-ai/openclaw:latest (from lantern-ai Docker registry)
# Custom: myregistry/my-openclaw:v1.2.3
OPENCLAW_IMAGE=lantern-ai/openclaw:latest

# Log level for OpenClaw service (DEBUG, INFO, WARNING, ERROR)
# DEBUG: verbose logging for troubleshooting agent discovery and skill registration
# INFO: normal operation (default)
OPENCLAW_LOG_LEVEL=INFO

# OpenClaw API port (internal to container, mapped to 8001 externally)
# Usually no need to change; controlled by docker-compose.yml
# OPENCLAW_API_PORT=8001 (set in docker-compose.yml, not here)

# OpenClaw configuration persistence
# Config stored at /root/.openclaw/openclaw.json inside container
# Mounted to openclaw_data Docker volume for persistence across reboots
# No need to set; automatically handled by docker-compose.yml volumes section

# ===== Home Assistant =====
HOME_ASSISTANT_URL=http://had.lthome.us
HOME_ASSISTANT_TOKEN=your_home_assistant_long_lived_access_token_here

# ===== Google APIs =====
# For Google Calendar and Gmail integration
# See https://cloud.google.com/docs/authentication/getting-started
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-creds.json
GOOGLE_CALENDAR_ID=your_family_calendar_id_here
GOOGLE_GMAIL_ADDRESS=your_email@gmail.com

# ===== OpenAI (LLM Backend) =====
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ===== Grocy (Grocery/Meal Planning) =====
GROCY_API_URL=http://grocery.lthome.us
GROCY_API_KEY=your_grocy_api_key_here

# ===== Water Usage Monitoring =====
WATER_API_URL=http://your-water-api-endpoint
WATER_API_KEY=your_water_api_key_here
WATER_API_TIMEOUT_SECONDS=10

# ===== Docker Integration =====
# For monitoring Docker hosts and container health
# Can be local socket or remote daemon
DOCKER_HOST_1=unix:///var/run/docker.sock
# Uncomment for remote Docker hosts:
# DOCKER_HOST_2=tcp://docker-pi-01.lthome.us:2375
# DOCKER_HOST_3=tcp://docker-pi-02.lthome.us:2375

# ===== Library Systems =====
KAVITA_URL=http://comics.lthome.us
KAVITA_API_KEY=your_kavita_api_key_here

CALIBRE_WEB_URL=http://books.lthome.us
CALIBRE_WEB_API_KEY=your_calibre_web_api_key_here

AUDIOBOOKSHELF_URL=http://audiobooks.lthome.us
AUDIOBOOKSHELF_API_KEY=your_audiobookshelf_api_key_here

# ===== Database Configuration =====
POSTGRES_USER=household_ai
POSTGRES_PASSWORD=your_very_secure_postgres_password_here_change_this
POSTGRES_DB=household_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis connection
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ===== Logging and Audit =====
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
LOG_FORMAT=json

# ===== Development/Testing =====
# Set to true to use mock data for all integrations (no real API calls)
MOCK_INTEGRATIONS=false

# ===== Advanced Configuration =====
# API rate limiting (requests per minute)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Confirmation timeout (seconds to wait for user approval)
CONFIRMATION_TIMEOUT_SECONDS=300

# Max concurrent agent invocations
MAX_CONCURRENT_AGENTS=5
