# Household AI with Traefik - Environment Variables Template
# Copy this file to .env and fill in real values for Traefik-based deployment
# NEVER commit .env to version control

# Most variables are the same as the base docker-compose setup
# This file highlights Traefik-specific settings

# ===== API Gateway =====
# Note: With Traefik, these are for internal container communication only
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ===== OpenClaw Integration =====
OPENCLAW_BASE_URL=http://localhost:8001
OPENCLAW_API_KEY=your_openclaw_api_key_here

# ===== OpenClaw Containerized Service =====
OPENCLAW_IMAGE=lantern-ai/openclaw:latest
OPENCLAW_LOG_LEVEL=INFO

# ===== Traefik Configuration =====
# Log level for Traefik (DEBUG, INFO, WARNING, ERROR)
TRAEFIK_LOG_LEVEL=INFO

# Traefik dashboard access: https://traefik-ai.lthome.us
# OpenClaw access: https://api.lthome.us
# Household API access: https://api-ai.lthome.us

# ===== SSL/TLS =====
# Self-signed certificates are generated in traefik/certs/
# Certificates valid for: lthome.us, *.lthome.us, api.lthome.us, api-ai.lthome.us, traefik-ai.lthome.us
# To regenerate: ./setup-ssl-certs.sh (Linux/macOS) or .\setup-ssl-certs.ps1 (Windows)

# For production with Let's Encrypt:
# 1. Edit traefik/traefik.yml to change caServer
# 2. Update docker-compose labels to use letsencrypt resolver
# 3. Ensure port 80 is accessible for HTTP-01 challenge

# ===== Home Assistant =====
HOME_ASSISTANT_URL=http://had.lthome.us
HOME_ASSISTANT_TOKEN=your_home_assistant_long_lived_access_token_here

# ===== Google APIs =====
# For Google Calendar and Gmail integration
# See https://cloud.google.com/docs/authentication/getting-started
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-creds.json
GOOGLE_CALENDAR_ID=your_family_calendar_id_here
GOOGLE_GMAIL_ADDRESS=your_email@gmail.com

# ===== OpenAI (LLM Backend) =====
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4

# ===== Grocy (Grocery/Meal Planning) =====
GROCY_API_URL=http://grocery.lthome.us
GROCY_API_KEY=your_grocy_api_key_here

# ===== Water Usage Monitoring =====
WATER_API_URL=http://your-water-api-endpoint
WATER_API_KEY=your_water_api_key_here
WATER_API_TIMEOUT_SECONDS=10

# ===== Docker Integration =====
# For monitoring Docker hosts and container health
DOCKER_HOST_1=unix:///var/run/docker.sock
# Uncomment for remote Docker hosts:
# DOCKER_HOST_2=tcp://docker-pi-01.lthome.us:2375

# ===== Library Services =====
KAVITA_URL=http://comics.lthome.us
KAVITA_API_KEY=your_kavita_api_key_here

CALIBRE_WEB_URL=http://books.lthome.us
CALIBRE_WEB_API_KEY=your_calibre_web_api_key_here

AUDIOBOOKSHELF_URL=http://audiobooks.lthome.us
AUDIOBOOKSHELF_API_KEY=your_audiobookshelf_api_key_here

# ===== Database =====
POSTGRES_USER=household_ai
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=household_ai

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== Features =====
MOCK_INTEGRATIONS=false  # Set true for development without real API keys
AUDIT_LOG_ENABLED=true
CONFIRMATION_TIMEOUT_SECONDS=300
